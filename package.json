{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "syohi",
  "title": "syohi",
  "description": "This command displays AI tool usage.\nCurrently, it supports Codex and OpenCode Go.",
  "icon": "extension-icon.png",
  "author": "50ki-1706",
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Data",
    "Developer Tools",
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "syouhi",
      "subtitle": "syohi",
      "description": "Show AI tool usage.",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.20",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
